# Cognitive Bias Spotter — Environment Variables
# NEVER commit this file. It is gitignored.
# Copy .env.example to .env and fill in your values.

# HuggingFace API token — get one at https://huggingface.co/settings/tokens
# Required for: model downloads, Layer 3 LLM inference via HF Inference API
HUGGINGFACE_TOKEN=your_token_here

# LLM backend selection: "huggingface" | "ollama" | "anthropic" | "openai"
LLM_BACKEND=huggingface

# Ollama settings (only needed if LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Anthropic API key (only needed if LLM_BACKEND=anthropic)
# ANTHROPIC_API_KEY=

# OpenAI API key (only needed if LLM_BACKEND=openai)
# OPENAI_API_KEY=
